{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build boot.bin",
            "type": "shell",
            "command": "make",
            "problemMatcher": []
        },
        {
            "label": "run qemu",
            "type": "shell",
            "command": "qemu-system-i386 -drive format=raw,file=boot.bin",
            "dependsOn": "build boot.bin",
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "debug qemu",
            "type": "shell",
            "command": "qemu-system-i386 -S -s -drive format=raw,file=boot.bin",
            "dependsOn": "build boot.bin",
            "dependsOrder": "sequence",
            "problemMatcher": []
        },
        {
            "label": "gdb attach",
            "type": "shell",
            "command": "gdb -q",
            "problemMatcher": []
        },
        {
            "label": "debug qemu + gdb",
            "dependsOn": ["debug qemu", "gdb attach"],
            "dependsOrder": "parallel",
            "problemMatcher": []
        }
    ]
}